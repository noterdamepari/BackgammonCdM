      <text font-family="SansSerif" font-size="8" text-anchor="middle" x="64" y="72">b_top</text>
      <circ-port height="8" pin="150,140" width="8" x="46" y="66"/>
      <circ-port height="10" pin="290,150" width="10" x="75" y="65"/>
