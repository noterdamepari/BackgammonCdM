{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Compile CdM-16",
			"type": "shell",
			"command": ".env/bin/cocas",
			"args": [
				"--target",
				"cdm16",
				"-o",
				"${workspaceFolder}/build/out.img",
				"--debug",
				"${workspaceFolder}/build/out.dbg.json",
				"${workspaceFolder}/run.asm", 
				"${workspaceFolder}/app/*.asm" 
			],
		}
	]
}
